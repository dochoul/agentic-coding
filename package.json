{
  "name": "user-dashboard",
  "version": "1.0.0",
  "description": "User Management Dashboard with Next.js",
  "engines": {
    "node": ">=20 <21"
  },
  "volta": {
    "node": "20.11.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:generate:insecure": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:insecure": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:migrate:reset:insecure": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma migrate reset",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:studio:insecure": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma studio",
    "db:push": "prisma db push",
    "db:push:insecure": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma db push",
    "db:seed:insecure": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma db seed"
  },
  "dependencies": {
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-query-devtools": "^5.17.19",
    "@prisma/client": "^5.8.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/bcryptjs": "^2.4.6",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "prisma": "^5.8.1"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
