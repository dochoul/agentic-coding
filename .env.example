# 데이터베이스 연결 URL
# PostgreSQL 형식: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@localhost:5432/user_dashboard?schema=public"

# (권장) 마이그레이션/관리 작업용 direct(비풀링) 연결
# Vercel Postgres를 쓰면 DIRECT_URL에 "Non-Pooling" 값을 넣는 것을 권장합니다.
DIRECT_URL="postgresql://postgres:password@localhost:5432/user_dashboard?schema=public"

# Next.js 환경 변수
NEXT_PUBLIC_APP_URL="http://localhost:3000"
